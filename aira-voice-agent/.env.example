# ═══ FILE: .env.example ═══
# Purpose: Template for environment variables
# Inputs: Configuration keys
# Outputs: Environment variable definitions for the app

# Application Configuration
APP_NAME="Aira — AI Receptionist"
DEBUG=True
PORT=8000
MOCK_MODE=True  # Set to True for testing without local dependencies (Ollama/FFmpeg)

# Model Configuration
# Available: llama3.2 (3B), mistral (7B), llama3.1 (8B), tinyllama
# Leave blank for auto-selection based on RAM
OLLAMA_MODEL=""
WHISPER_MODEL="base"

# TTS Configuration
# Coqui: tts_models/en/ljspeech/vits
TTS_MODEL="tts_models/en/ljspeech/vits"
TTS_ENGINE="coqui" # coqui or pyttsx3

# Session Configuration
SESSION_TTL=1800
DATA_DIR="./data"
