# ═══ FILE: .env.example ═══
# Production API Keys for Aira Voice Agent

# Groq API Key (from groq.com)
GROQ_API_KEY="gsk_..."

# OpenRouter API Key (from openrouter.ai)
OPENROUTER_API_KEY="sk-or-..."

# Application Settings
APP_NAME="Aira — Psycholab AI"
PORT=8000
DEBUG=True

# LLM Configuration (OpenRouter Free Llama 3.1 8B)
OPENROUTER_MODEL="meta-llama/llama-3.1-8b-instruct:free"

# TTS Configuration (Cartesia Sonic-3 English)
CARTESIA_API_KEY="your_api_key_here"
CARTESIA_VOICE_ID="9626c31c-bec5-4cca-baa8-f8ba9e84c8bc"
TTS_VOICE="en-US-JennyNeural"
